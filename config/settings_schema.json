[
  {
    "name": "theme_info",
    "theme_name": "BlueMnky",
    "theme_version": "2.0.0",
    "theme_author": "Lunatic Themes",
    "theme_documentation_url": "https://help.shopify.com",
    "theme_support_url": "https://help.shopify.com"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Primary Colors"
      },
      {
        "type": "color",
        "id": "accent_color",
        "label": "Accent color",
        "default": "#e12d2d",
        "info": "Used for buttons, links, and highlights"
      },
      {
        "type": "color",
        "id": "accent_color_dark",
        "label": "Accent color (dark)",
        "default": "#c12626"
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Text color",
        "default": "#1a1a1a"
      },
      {
        "type": "color",
        "id": "text_muted_color",
        "label": "Muted text color",
        "default": "#888888"
      },
      {
        "type": "color",
        "id": "heading_color",
        "label": "Heading color",
        "default": "#1a1a1a"
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Background color",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "surface_color",
        "label": "Surface color",
        "default": "#f5f5f5",
        "info": "Used for cards and alternate backgrounds"
      },
      {
        "type": "color",
        "id": "border_color",
        "label": "Border color",
        "default": "#d5d5d5"
      },
      {
        "type": "header",
        "content": "Header Colors"
      },
      {
        "type": "color",
        "id": "header_bg_color",
        "label": "Header background",
        "default": "#ffffff",
        "info": "Clean white header like Souled Store"
      },
      {
        "type": "color",
        "id": "header_text_color",
        "label": "Header text/icon color",
        "default": "#e12d2d"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "heading_font",
        "label": "Heading font",
        "default": "poppins_n6"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "label": "Body font",
        "default": "poppins_n4"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "select",
        "id": "container_width",
        "label": "Container width",
        "default": "1440px",
        "options": [
          {
            "value": "1080px",
            "label": "Narrow (1080px)"
          },
          {
            "value": "1280px",
            "label": "Default (1280px)"
          },
          {
            "value": "1440px",
            "label": "Wide (1440px)"
          }
        ]
      },
      {
        "type": "text",
        "id": "grid_gutter",
        "label": "Grid gutter",
        "default": "24px",
        "info": "Spacing between grid items (e.g., 20px, 24px)"
      },
      {
        "type": "range",
        "id": "section_spacing",
        "label": "Section spacing",
        "min": 40,
        "max": 120,
        "step": 10,
        "unit": "px",
        "default": 60
      },
      {
        "type": "range",
        "id": "border_radius",
        "label": "Border radius",
        "min": 0,
        "max": 16,
        "step": 2,
        "unit": "px",
        "default": 0
      },
      {
        "type": "select",
        "id": "text_direction",
        "label": "Text direction",
        "default": "ltr",
        "options": [
          {
            "value": "ltr",
            "label": "Left to Right"
          },
          {
            "value": "rtl",
            "label": "Right to Left"
          }
        ]
      }
    ]
  },
  {
    "name": "Integrations",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_shopflo",
        "label": "Enable Shopflo checkout",
        "default": false,
        "info": "Loads the Shopflo checkout bridge script. Disable to use Shopify's native checkout."
      }
    ]
  },
  {
    "name": "Animations & Effects",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_animations",
        "label": "Enable scroll animations",
        "default": true,
        "info": "Elements will animate as they scroll into view"
      },
      {
        "type": "checkbox",
        "id": "enable_custom_cursor",
        "label": "Enable custom cursor",
        "default": false,
        "info": "Shows custom cursor on desktop only"
      },
      {
        "type": "checkbox",
        "id": "enable_newsletter_popup",
        "label": "Enable newsletter popup",
        "default": true
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook URL"
      },
      {
        "type": "text",
        "id": "social_twitter",
        "label": "Twitter/X URL"
      },
      {
        "type": "text",
        "id": "social_pinterest",
        "label": "Pinterest URL"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok URL"
      },
      {
        "type": "text",
        "id": "social_linkedin",
        "label": "LinkedIn URL"
      }
    ]
  },
  {
    "name": "WhatsApp",
    "settings": [
      {
        "type": "text",
        "id": "whatsapp_number",
        "label": "WhatsApp number",
        "info": "Include country code, e.g. +919876543210. Shows floating chat button on all pages."
      }
    ]
  },
  {
    "name": "Product page",
    "settings": [
      {
        "type": "header",
        "content": "Promo banner"
      },
      {
        "type": "checkbox",
        "id": "product_promo_enabled",
        "label": "Show promo banner on product page",
        "default": true
      },
      {
        "type": "text",
        "id": "product_promo_text",
        "label": "Promo text",
        "default": "Get Flat ₹100 Off on your first order"
      },
      {
        "type": "text",
        "id": "product_promo_code",
        "label": "Coupon code",
        "default": "WELCOMENEW"
      },
      {
        "type": "header",
        "content": "Ratings"
      },
      {
        "type": "checkbox",
        "id": "product_show_rating",
        "label": "Show star rating",
        "default": true,
        "info": "Displays star rating and review count. Uses the reviews metafield if available."
      },
      {
        "type": "header",
        "content": "Delivery estimate"
      },
      {
        "type": "range",
        "id": "product_delivery_min_days",
        "label": "Minimum delivery days",
        "min": 1,
        "max": 30,
        "step": 1,
        "default": 5
      },
      {
        "type": "range",
        "id": "product_delivery_max_days",
        "label": "Maximum delivery days",
        "min": 2,
        "max": 45,
        "step": 1,
        "default": 7
      },
      {
        "type": "header",
        "content": "Tax note"
      },
      {
        "type": "text",
        "id": "product_tax_note",
        "label": "Tax / pricing note",
        "default": "incl. of all taxes",
        "info": "Shown below the price. Leave blank to hide."
      },
      {
        "type": "header",
        "content": "Trust badges"
      },
      {
        "type": "text",
        "id": "product_trust_1",
        "label": "Trust badge 1",
        "default": "Free Shipping ₹999+"
      },
      {
        "type": "text",
        "id": "product_trust_2",
        "label": "Trust badge 2",
        "default": "10-Day Returns"
      },
      {
        "type": "text",
        "id": "product_trust_3",
        "label": "Trust badge 3",
        "default": "Secure Checkout"
      },
      {
        "type": "text",
        "id": "product_trust_4",
        "label": "Trust badge 4",
        "default": "COD Available"
      },
      {
        "type": "header",
        "content": "Accordion content"
      },
      {
        "type": "richtext",
        "id": "product_shipping_text",
        "label": "Shipping & Returns text",
        "default": "<p>Free standard shipping on all orders over ₹999. Express shipping available at checkout. 10-day hassle-free returns on all items. Cash on Delivery (COD) available.</p>"
      },
      {
        "type": "richtext",
        "id": "product_care_text",
        "label": "Care Instructions text",
        "default": "<p>Please refer to the product label for specific care instructions. For best results, follow the recommended guidelines.</p>"
      },
      {
        "type": "header",
        "content": "Share"
      },
      {
        "type": "checkbox",
        "id": "product_show_share",
        "label": "Show share buttons",
        "default": true
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "checkbox",
        "id": "cart_show_shipping_bar",
        "label": "Show free-shipping progress bar",
        "default": true
      },
      {
        "type": "text",
        "id": "cart_free_shipping_threshold",
        "label": "Free-shipping threshold (₹)",
        "default": "999",
        "info": "Enter amount in rupees, e.g. 999"
      },
      {
        "type": "text",
        "id": "cart_shipping_success_text",
        "label": "Success message",
        "default": "You've unlocked <strong>free shipping!</strong>"
      },
      {
        "type": "text",
        "id": "cart_shipping_progress_text",
        "label": "Progress message",
        "default": "Add <strong>[amount]</strong> more for <strong>free shipping</strong>",
        "info": "Use [amount] as placeholder for the remaining amount"
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "32 x 32px .png recommended"
      }
    ]
  }
]
