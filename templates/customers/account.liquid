<div class="page-template page-template--account">
<div class="container">

  <!-- Dashboard Hero -->
  <div class="acct-hero" data-animate="fade-up">
    <div class="acct-hero__avatar">
      {{ customer.first_name | slice: 0 | upcase }}{{ customer.last_name | slice: 0 | upcase }}
    </div>
    <div class="acct-hero__info">
      <h1 class="acct-hero__greeting">Hey, {{ customer.first_name }}!</h1>
      <p class="acct-hero__sub">{{ customer.email }}</p>
    </div>
    <a href="{{ routes.account_logout_url }}" class="acct-hero__logout">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      Log out
    </a>
  </div>

  <!-- Quick Action Tiles -->
  <div class="acct-actions" data-animate="fade-up" data-animate-delay="100">
    <a href="#acct-orders" class="acct-actions__tile">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 10h20"/></svg>
      <span>Orders</span>
      <span class="acct-actions__count">{{ customer.orders.size }}</span>
    </a>
    <a href="{{ routes.account_addresses_url }}" class="acct-actions__tile">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
      <span>Addresses</span>
      <span class="acct-actions__count">{{ customer.addresses.size }}</span>
    </a>
    <a href="{{ routes.root_url }}" class="acct-actions__tile">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span>Shop Now</span>
    </a>
  </div>

  <!-- Main Content Grid -->
  <div class="acct-grid" data-animate="fade-up" data-animate-delay="200">

    <!-- Order History -->
    <div class="acct-section" id="acct-orders">
      <div class="acct-section__head">
        <h2 class="acct-section__title">Order History</h2>
        {% if customer.orders.size > 0 %}
          <span class="acct-section__count">{{ customer.orders.size }} order{{ customer.orders.size | minus: 1 | at_least: 1 | times: 0 | plus: customer.orders.size | pluralize: '', 's' }}</span>
        {% endif %}
      </div>

      {% if customer.orders.size > 0 %}
        <div class="acct-orders">
          {% for order in customer.orders %}
          <a href="{{ order.customer_url }}" class="acct-order">
            <div class="acct-order__top">
              <span class="acct-order__id">{{ order.name }}</span>
              <span class="acct-order__status acct-order__status--{{ order.financial_status }}">{{ order.financial_status_label }}</span>
            </div>
            <div class="acct-order__details">
              <span class="acct-order__date">{{ order.created_at | date: '%b %d, %Y' }}</span>
              <span class="acct-order__dot"></span>
              <span class="acct-order__items">{{ order.line_items.size }} item{{ order.line_items.size | minus: 1 | at_least: 1 | times: 0 | plus: order.line_items.size | pluralize: '', 's' }}</span>
            </div>
            <div class="acct-order__bottom">
              <span class="acct-order__total">{{ order.total_price | money }}</span>
              <span class="acct-order__arrow">&rarr;</span>
            </div>
          </a>
          {% endfor %}
        </div>
      {% else %}
        <div class="acct-empty">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-border)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 10h20"/></svg>
          <p class="acct-empty__text">No orders yet</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Start Shopping</a>
        </div>
      {% endif %}
    </div>

    <!-- Account Details -->
    <div class="acct-section">
      <div class="acct-section__head">
        <h2 class="acct-section__title">Account Details</h2>
      </div>

      <div class="acct-detail">
        <div class="acct-detail__row">
          <span class="acct-detail__label">Name</span>
          <span class="acct-detail__value">{{ customer.name }}</span>
        </div>
        <div class="acct-detail__row">
          <span class="acct-detail__label">Email</span>
          <span class="acct-detail__value">{{ customer.email }}</span>
        </div>
        {% if customer.phone %}
        <div class="acct-detail__row">
          <span class="acct-detail__label">Phone</span>
          <span class="acct-detail__value">{{ customer.phone }}</span>
        </div>
        {% endif %}
      </div>

      {% if customer.default_address %}
      <div class="acct-address-card">
        <div class="acct-address-card__head">
          <span class="acct-address-card__badge">Default Address</span>
        </div>
        <p class="acct-address-card__text">
          {{ customer.default_address.address1 }}{% if customer.default_address.address2 != blank %}, {{ customer.default_address.address2 }}{% endif %}<br>
          {{ customer.default_address.city }}, {{ customer.default_address.province }} {{ customer.default_address.zip }}<br>
          {{ customer.default_address.country }}
        </p>
        <a href="{{ routes.account_addresses_url }}" class="acct-address-card__link">
          Manage Addresses
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      {% else %}
      <a href="{{ routes.account_addresses_url }}" class="btn btn--secondary btn--small mt-2">Add an Address</a>
      {% endif %}
    </div>

  </div>
</div>
</div>