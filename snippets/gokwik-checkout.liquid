{% if settings.goEnable %}
<div class="gokwik-checkout"{% if settings.hideFlow %} style="display:none !important;" {% endif %}>
<button type='button' class="btn btn--primary btn--full disabled" disabled onclick="onCheckoutClick(this)">
  <span class="btn-text">
    <span>{{ settings.main-titile | default: 'Checkout' }}</span>
    {% if settings.sub-titile != blank %}<span>{{ settings.sub-titile }}</span>{% endif %}
  </span>
  {% if settings.enableLogo %}
  <span class="pay-opt-icon">
    <img src="https://cdn.gokwik.co/v4/images/upi-icons.svg">
    <img src="https://cdn.gokwik.co/v4/images/right-arrow.svg">
  </span>
  {% endif %}
  <div style="display:none" class="addloadr" id="btn-loader">
    <div class="cir-loader">Loading..</div>
  </div>
</button>
</div>
{% endif %}
